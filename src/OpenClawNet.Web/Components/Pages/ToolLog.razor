@page "/tool-log"
@rendermode InteractiveServer

<PageTitle>OpenClaw .NET - Tool Execution Log</PageTitle>

<h3>Tool Execution Log</h3>

<p class="text-muted">
    Real-time log of tool calls made by the agent during chat conversations.
</p>

@if (_logs.Count == 0)
{
    <div class="alert alert-info">
        No tool executions recorded yet. Chat with the agent and request actions that require tools.
    </div>
}
else
{
    <MudDataGrid T="ToolLogEntry"
                 Items="_logs"
                 Dense="_dense"
                 Hover="true"
                 Striped="true"
                 Bordered="false"
                 Filterable="true"
                 SortMode="SortMode.Single"
                 ShowColumnOptions="true"
                 Groupable="false"
                 FixedHeader="true"
                 Height="70vh"
                 Elevation="0">
        <ToolBarContent>
            <MudText Typo="Typo.subtitle2">@_logs.Count tool execution(s)</MudText>
            <MudSpacer />
            <MudSwitch T="bool" Value="_dense" ValueChanged="v => _dense = v"
                       Color="Color.Primary" Label="@(_dense ? "Compact" : "Comfortable")" />
        </ToolBarContent>
        <Columns>
            <PropertyColumn Property="x => x.Timestamp" Title="Time" Format="HH:mm:ss"
                            InitialDirection="SortDirection.Descending" />
            <PropertyColumn Property="x => x.ToolName" Title="Tool">
                <CellTemplate>
                    <MudChip T="string" Size="Size.Small" Color="Color.Info" Variant="Variant.Filled">@context.Item.ToolName</MudChip>
                </CellTemplate>
            </PropertyColumn>
            <PropertyColumn Property="x => x.Success" Title="Status">
                <CellTemplate>
                    @if (context.Item.Success)
                    {
                        <MudChip T="string" Size="Size.Small" Color="Color.Success" Variant="Variant.Filled">✓ OK</MudChip>
                    }
                    else
                    {
                        <MudChip T="string" Size="Size.Small" Color="Color.Error" Variant="Variant.Filled">✗ Failed</MudChip>
                    }
                </CellTemplate>
            </PropertyColumn>
            <PropertyColumn Property="x => x.Duration.TotalMilliseconds" Title="Duration (ms)" Format="F0" />
        </Columns>
        <ChildRowContent>
            <MudCard Elevation="0" Class="pa-2 mud-background-gray">
                <MudText Typo="Typo.subtitle2">Arguments</MudText>
                <pre class="small mb-2">@context.Item.Arguments</pre>
                <MudText Typo="Typo.subtitle2">@(context.Item.Success ? "Output" : "Error")</MudText>
                <pre class="small mb-0" style="max-height: 200px; overflow-y: auto;">@(context.Item.Success ? context.Item.Output : context.Item.Error)</pre>
            </MudCard>
        </ChildRowContent>
        <PagerContent>
            <MudDataGridPager T="ToolLogEntry" PageSizeOptions="new[] { 10, 25, 50, 100 }" />
        </PagerContent>
    </MudDataGrid>
}

@code {
    private readonly List<ToolLogEntry> _logs = [];
    private bool _dense = true;

    private sealed class ToolLogEntry
    {
        public DateTime Timestamp { get; set; }
        public string ToolName { get; set; } = string.Empty;
        public bool Success { get; set; }
        public TimeSpan Duration { get; set; }
        public string Arguments { get; set; } = string.Empty;
        public string Output { get; set; } = string.Empty;
        public string? Error { get; set; }
    }
}

