@page "/settings/mcp"
@page "/mcp-tools"
@rendermode InteractiveServer
@using System.Net.Http.Json
@using OpenClawNet.Web.Components.Pages.McpSettings
@inject IHttpClientFactory HttpClientFactory
@inject NavigationManager Nav
@inject ILogger<Index> Logger
@implements IDisposable

<PageTitle>OpenClaw .NET - MCP Tools</PageTitle>

<h3>MCP Tools</h3>
<p class="text-muted small">
    Each MCP server contributes a set of tools the agent can call.
    Built-in servers ship with OpenClawNet and can be enabled or disabled but not edited.
    Add user servers via stdio (subprocess) or HTTP (Streamable HTTP).
</p>

<div class="d-flex justify-content-between align-items-center mb-3">
    <span class="text-muted">@_servers.Count server(s)</span>
    <div class="d-flex gap-2">
        <button class="btn btn-primary btn-sm" @onclick="@(() => Nav.NavigateTo("/settings/mcp/new"))">
            <i class="bi bi-plus-lg me-1"></i> Add MCP Server
        </button>
        <button class="btn btn-outline-primary btn-sm" @onclick="@(() => Nav.NavigateTo("/settings/mcp/registry"))">
            <i class="bi bi-search me-1"></i> Browse Registry
        </button>
        <button class="btn btn-outline-primary btn-sm" @onclick="@(() => Nav.NavigateTo("/settings/mcp/suggestions"))">
            <i class="bi bi-stars me-1"></i> Suggestions
        </button>
    </div>
</div>

@if (_loading)
{
    <div class="text-muted"><span class="spinner-border spinner-border-sm me-2" role="status"></span>Loading MCP servers…</div>
}
else if (!string.IsNullOrEmpty(_error))
{
    <div class="alert alert-danger py-2 small">@_error</div>
}
else if (_servers.Count == 0)
{
    <div class="alert alert-info">No MCP servers configured.</div>
}
else
{
    <MudDataGrid T="McpDtos.McpServerListItem"
                 Items="_servers"
                 Dense="_dense"
                 Hover="true"
                 Striped="true"
                 Bordered="false"
                 Filterable="true"
                 SortMode="SortMode.Single"
                 ShowColumnOptions="true"
                 Groupable="false"
                 FixedHeader="true"
                 Height="70vh"
                 Elevation="0">
        <ToolBarContent>
            <MudText Typo="Typo.subtitle2">@_servers.Count server(s)</MudText>
            <MudSpacer />
            <MudSwitch T="bool" Value="_dense" ValueChanged="v => _dense = v"
                       Color="Color.Primary" Label="@(_dense ? "Compact" : "Comfortable")" />
        </ToolBarContent>
        <Columns>
            <PropertyColumn Property="x => x.Name" Title="Name">
                <CellTemplate>
                    <code data-testid="mcp-row-@context.Item.Name">@context.Item.Name</code>
                    @if (context.Item.IsBuiltIn)
                    {
                        <MudChip T="string" Size="Size.Small" Color="Color.Secondary" Variant="Variant.Filled" Class="ms-2" title="Built-in MCP server">Built-in</MudChip>
                    }
                </CellTemplate>
            </PropertyColumn>
            <PropertyColumn Property="x => x.Transport" Title="Transport">
                <CellTemplate>
                    <MudChip T="string" Size="Size.Small" Color="Color.Default" Variant="Variant.Outlined">@context.Item.Transport</MudChip>
                </CellTemplate>
            </PropertyColumn>
            <TemplateColumn Title="Status" SortBy="x => x.Enabled ? (string.IsNullOrEmpty(x.LastError) ? (x.IsRunning ? 0 : 2) : 1) : 3">
                <CellTemplate>
                    @if (!context.Item.Enabled)
                    {
                        <MudChip T="string" Size="Size.Small" Color="Color.Warning" Variant="Variant.Filled">🟡 Disabled</MudChip>
                    }
                    else if (!string.IsNullOrEmpty(context.Item.LastError))
                    {
                        <MudChip T="string" Size="Size.Small" Color="Color.Error" Variant="Variant.Filled">🔴 Error</MudChip>
                    }
                    else if (context.Item.IsRunning)
                    {
                        <MudChip T="string" Size="Size.Small" Color="Color.Success" Variant="Variant.Filled">🟢 Running</MudChip>
                    }
                    else
                    {
                        <MudChip T="string" Size="Size.Small" Color="Color.Secondary" Variant="Variant.Filled">⚪ Stopped</MudChip>
                    }
                </CellTemplate>
            </TemplateColumn>
            <PropertyColumn Property="x => x.ToolCount" Title="Tools">
                <CellTemplate>
                    @(context.Item.ToolCount > 0 ? context.Item.ToolCount.ToString() : "—")
                </CellTemplate>
            </PropertyColumn>
            <PropertyColumn Property="x => x.LastError" Title="Last error">
                <CellTemplate>
                    @if (!string.IsNullOrEmpty(context.Item.LastError))
                    {
                        <span class="text-danger small" title="@context.Item.LastError">
                            @(context.Item.LastError!.Length > 40 ? context.Item.LastError[..40] + "…" : context.Item.LastError)
                        </span>
                    }
                    else
                    {
                        <span class="text-muted">—</span>
                    }
                </CellTemplate>
            </PropertyColumn>
            <TemplateColumn Title="Actions" Sortable="false" Filterable="false" CellClass="text-end">
                <CellTemplate>
                    <button class="btn btn-outline-secondary btn-sm me-1"
                            @onclick="() => ToggleEnabledAsync(context.Item)" disabled="@_busy">
                        @(context.Item.Enabled ? "Disable" : "Enable")
                    </button>
                    <button class="btn btn-outline-info btn-sm me-1" @onclick="() => TestAsync(context.Item.Id)" disabled="@_busy">
                        Test
                    </button>
                    @if (!context.Item.IsBuiltIn)
                    {
                        <button class="btn btn-outline-primary btn-sm me-1"
                                @onclick="@(() => Nav.NavigateTo($"/settings/mcp/{context.Item.Id}"))">
                            Edit
                        </button>
                        <button class="btn btn-outline-danger btn-sm" @onclick="() => DeleteAsync(context.Item)" disabled="@_busy">
                            Delete
                        </button>
                    }
                </CellTemplate>
            </TemplateColumn>
        </Columns>
        <ChildRowContent>
            @if (_lastTest.TryGetValue(context.Item.Id, out var t))
            {
                <MudCard Elevation="0" Class="pa-2 mud-background-gray">
                    @if (t.Ok)
                    {
                        <div>
                            <MudChip T="string" Size="Size.Small" Color="Color.Success" Variant="Variant.Filled">✅ @t.Tools.Length tool(s)</MudChip>
                            <span class="ms-2 small text-muted">
                                @string.Join(", ", t.Tools.Take(8).Select(x => x.Name))
                                @(t.Tools.Length > 8 ? " …" : "")
                            </span>
                        </div>
                    }
                    else
                    {
                        <MudChip T="string" Size="Size.Small" Color="Color.Error" Variant="Variant.Filled">❌ @t.Error</MudChip>
                    }
                </MudCard>
            }
            else
            {
                <MudText Typo="Typo.caption" Class="pa-2 text-muted">
                    Click <strong>Test</strong> to probe this server and list its tools here.
                </MudText>
            }
        </ChildRowContent>
        <PagerContent>
            <MudDataGridPager T="McpDtos.McpServerListItem" PageSizeOptions="new[] { 10, 25, 50, 100 }" />
        </PagerContent>
    </MudDataGrid>
}

@code {
    private bool _loading = true;
    private bool _busy;
    private bool _dense = true;
    private string? _error;
    private List<McpDtos.McpServerListItem> _servers = new();
    private Dictionary<Guid, McpDtos.TestResult> _lastTest = new();
    private System.Threading.Timer? _refreshTimer;

    protected override async Task OnInitializedAsync()
    {
        await LoadAsync();
        _loading = false;
        _refreshTimer = new System.Threading.Timer(async _ =>
        {
            try
            {
                await LoadAsync();
                await InvokeAsync(StateHasChanged);
            }
            catch (Exception ex) { Logger.LogDebug(ex, "Background refresh failed."); }
        }, null, TimeSpan.FromSeconds(10), TimeSpan.FromSeconds(10));
    }

    public void Dispose() => _refreshTimer?.Dispose();

    private async Task LoadAsync()
    {
        try
        {
            var http = HttpClientFactory.CreateClient("gateway");
            var result = await http.GetFromJsonAsync<List<McpDtos.McpServerListItem>>("/api/mcp/servers");
            _servers = result ?? new();
            _error = null;
        }
        catch (Exception ex)
        {
            Logger.LogWarning(ex, "Failed to load MCP servers");
            _error = "Could not reach the Gateway to load MCP servers.";
        }
    }

    private async Task ToggleEnabledAsync(McpDtos.McpServerListItem s)
    {
        _busy = true;
        try
        {
            var http = HttpClientFactory.CreateClient("gateway");
            var body = new McpDtos.ServerWriteRequest
            {
                Name = s.Name,
                Transport = s.Transport,
                Command = s.Command,
                Args = s.Args.ToList(),
                Url = s.Url,
                Enabled = !s.Enabled,
            };
            var resp = await http.PutAsJsonAsync($"/api/mcp/servers/{s.Id}", body);
            if (!resp.IsSuccessStatusCode) _error = $"Toggle failed ({(int)resp.StatusCode}).";
            await LoadAsync();
        }
        finally { _busy = false; }
    }

    private async Task TestAsync(Guid id)
    {
        _busy = true;
        try
        {
            var http = HttpClientFactory.CreateClient("gateway");
            var resp = await http.PostAsync($"/api/mcp/servers/{id}/test", null);
            var result = await resp.Content.ReadFromJsonAsync<McpDtos.TestResult>();
            if (result is not null) _lastTest[id] = result;
        }
        catch (Exception ex)
        {
            _lastTest[id] = new McpDtos.TestResult(false, Array.Empty<McpDtos.ToolDescriptor>(), ex.Message);
        }
        finally { _busy = false; }
    }

    private async Task DeleteAsync(McpDtos.McpServerListItem s)
    {
        _busy = true;
        try
        {
            var http = HttpClientFactory.CreateClient("gateway");
            var resp = await http.DeleteAsync($"/api/mcp/servers/{s.Id}");
            if (!resp.IsSuccessStatusCode) _error = $"Delete failed ({(int)resp.StatusCode}).";
            await LoadAsync();
        }
        finally { _busy = false; }
    }
}
