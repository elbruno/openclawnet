@page "/jobs/{JobId:guid}/runs/{RunId:guid}/events"
@rendermode InteractiveServer
@using OpenClawNet.Web.Models.Jobs
@inject OpenClawNet.Web.Services.JobsClient JobsClient

<PageTitle>OpenClaw .NET - Run Events</PageTitle>

<h3>🕒 Run Timeline</h3>
<p class="text-muted small">
    Persisted timeline of what happened during this job run. Survives app restarts (unlike OTEL traces).
    <a href="/jobs">← Back to Jobs</a>
</p>

@if (_loading)
{
    <p>Loading events…</p>
}
else if (_error is not null)
{
    <div class="alert alert-danger">@_error</div>
}
else if (_events.Count == 0)
{
    <div class="alert alert-info">No events found for this run. Either the run pre-dates the run-events feature, or it was a dry-run.</div>
}
else
{
    <MudDataGrid T="JobRunEventDto"
                 ServerData="LoadGridDataAsync"
                 Dense="_dense"
                 Hover="true"
                 Striped="true"
                 Bordered="false"
                 Filterable="true"
                 SortMode="SortMode.Single"
                 ShowColumnOptions="true"
                 Groupable="false"
                 FixedHeader="true"
                 Height="70vh"
                 Elevation="0">
        <ToolBarContent>
            <MudText Typo="Typo.subtitle2">@_events.Count event(s)</MudText>
            <MudSpacer />
            <MudSwitch T="bool" Value="_dense" ValueChanged="v => _dense = v"
                       Color="Color.Primary" Label="@(_dense ? "Compact" : "Comfortable")" />
        </ToolBarContent>
        <Columns>
            <PropertyColumn Property="x => x.Sequence" Title="#" />
            <PropertyColumn Property="x => x.Timestamp" Title="When">
                <CellTemplate>
                    <small data-testid="run-event-row-@context.Item.Sequence">@context.Item.Timestamp.ToString("yyyy-MM-dd HH:mm:ss")</small>
                </CellTemplate>
            </PropertyColumn>
            <PropertyColumn Property="x => x.Kind" Title="Kind">
                <CellTemplate>
                    <MudChip T="string" Size="Size.Small"
                             Color="@KindChipColor(context.Item.Kind)"
                             Variant="Variant.Filled">@context.Item.Kind</MudChip>
                </CellTemplate>
            </PropertyColumn>
            <PropertyColumn Property="x => x.ToolName" Title="Tool">
                <CellTemplate>@(context.Item.ToolName ?? "—")</CellTemplate>
            </PropertyColumn>
            <TemplateColumn Title="Details" Sortable="false" Filterable="false">
                <CellTemplate>
                    @{ var e = context.Item; }
                    @if (!string.IsNullOrEmpty(e.Message))
                    {
                        <div class="small">@e.Message</div>
                    }
                    @if (!string.IsNullOrEmpty(e.ArgumentsJson))
                    {
                        <details class="small">
                            <summary>args</summary>
                            <pre class="bg-light p-2 mb-1" style="white-space:pre-wrap;max-height:200px;overflow:auto;">@e.ArgumentsJson</pre>
                        </details>
                    }
                    @if (!string.IsNullOrEmpty(e.ResultJson))
                    {
                        <details class="small">
                            <summary>result</summary>
                            <pre class="bg-light p-2 mb-0" style="white-space:pre-wrap;max-height:200px;overflow:auto;">@e.ResultJson</pre>
                        </details>
                    }
                </CellTemplate>
            </TemplateColumn>
            <PropertyColumn Property="x => x.DurationMs" Title="Duration" CellClass="text-end">
                <CellTemplate>
                    <small>@(context.Item.DurationMs.HasValue ? $"{context.Item.DurationMs} ms" : "—")</small>
                </CellTemplate>
            </PropertyColumn>
            <PropertyColumn Property="x => x.TokensUsed" Title="Tokens" CellClass="text-end">
                <CellTemplate>
                    <small>@(context.Item.TokensUsed.HasValue ? context.Item.TokensUsed.ToString() : "—")</small>
                </CellTemplate>
            </PropertyColumn>
        </Columns>
        <PagerContent>
            <MudDataGridPager T="JobRunEventDto" PageSizeOptions="new[] { 25, 50, 100, 250 }" />
        </PagerContent>
    </MudDataGrid>
}

@code {
    [Parameter] public Guid JobId { get; set; }
    [Parameter] public Guid RunId { get; set; }

    private List<JobRunEventDto> _events = [];
    private bool _loading = true;
    private bool _dense = true;
    private string? _error;

    protected override async Task OnInitializedAsync()
    {
        try
        {
            _events = (await JobsClient.GetRunEventsAsync(JobId, RunId)).ToList();
        }
        catch (Exception ex)
        {
            _error = $"Failed to load events: {ex.Message}";
        }
        finally
        {
            _loading = false;
        }
    }

    // ServerData callback — paging/sort/filter from grid state, applied over the in-memory list
    private Task<GridData<JobRunEventDto>> LoadGridDataAsync(GridState<JobRunEventDto> state, CancellationToken ct)
    {
        IEnumerable<JobRunEventDto> q = _events;

        foreach (var fd in state.FilterDefinitions)
        {
            var func = fd.GenerateFilterFunction();
            q = q.Where(func);
        }

        foreach (var sd in state.SortDefinitions)
        {
            q = sd.Descending
                ? q.OrderByDescending(x => sd.SortFunc(x))
                : q.OrderBy(x => sd.SortFunc(x));
        }

        var list = q.ToList();
        var total = list.Count;
        var page = list.Skip(state.Page * state.PageSize).Take(state.PageSize).ToList();

        return Task.FromResult(new GridData<JobRunEventDto>
        {
            Items = page,
            TotalItems = total,
        });
    }

    private static Color KindChipColor(string kind) => kind switch
    {
        "agent_started"   => Color.Info,
        "tool_call"       => Color.Primary,
        "agent_completed" => Color.Success,
        "agent_failed"    => Color.Error,
        "profile_refused" => Color.Warning,
        _                 => Color.Secondary,
    };
}
