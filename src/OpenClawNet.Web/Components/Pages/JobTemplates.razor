@page "/jobs/templates"
@rendermode InteractiveServer
@using OpenClawNet.Web.Models.Jobs
@inject OpenClawNet.Web.Services.JobsClient JobsClient
@inject NavigationManager Navigation

<PageTitle>OpenClaw .NET - Job Templates</PageTitle>

<h3>📄 Job Templates</h3>

<p class="text-muted">
    Pre-canned job configurations distilled from the <a href="https://github.com/elbruno/openclawnet-plan/tree/main/docs/demos/tools" target="_blank">demos in <code>docs/demos/tools/</code></a>.
    Pick one, review the prerequisites, and click <strong>Use this template</strong> to create a job seeded with its prompt, schedule, and tool list.
</p>

@if (_loading)
{
    <p>Loading templates…</p>
}
else if (_error is not null)
{
    <div class="alert alert-danger">@_error</div>
}
else if (_templates.Count == 0)
{
    <div class="alert alert-warning">No templates returned by the gateway.</div>
}
else
{
    <MudDataGrid T="JobTemplateDto"
                 Items="_templates"
                 Dense="_dense"
                 Hover="true"
                 Striped="true"
                 Bordered="false"
                 Filterable="true"
                 SortMode="SortMode.Single"
                 ShowColumnOptions="true"
                 Groupable="false"
                 FixedHeader="true"
                 Height="70vh"
                 Elevation="0">
        <ToolBarContent>
            <MudText Typo="Typo.subtitle2">@_templates.Count template(s)</MudText>
            <MudSpacer />
            <MudSwitch T="bool" Value="_dense" ValueChanged="v => _dense = v"
                       Color="Color.Primary" Label="@(_dense ? "Compact" : "Comfortable")" />
        </ToolBarContent>
        <Columns>
            <PropertyColumn Property="x => x.Name" Title="Name" />
            <PropertyColumn Property="x => x.Category" Title="Category">
                <CellTemplate>
                    @if (!string.IsNullOrEmpty(context.Item.Category))
                    {
                        <MudChip T="string" Size="Size.Small" Color="Color.Secondary" Variant="Variant.Filled">@context.Item.Category</MudChip>
                    }
                </CellTemplate>
            </PropertyColumn>
            <PropertyColumn Property="x => x.Description" Title="Description" />
            <TemplateColumn Title="Schedule" Sortable="false" Filterable="false">
                <CellTemplate>
                    @if (!string.IsNullOrEmpty(context.Item.DefaultJob.CronExpression))
                    {
                        <code class="small">@context.Item.DefaultJob.CronExpression</code>
                    }
                    else
                    {
                        <span class="text-muted small">—</span>
                    }
                </CellTemplate>
            </TemplateColumn>
            <TemplateColumn Title="Tools" Sortable="false" Filterable="false">
                <CellTemplate>
                    @foreach (var tool in context.Item.RequiredTools)
                    {
                        <MudChip T="string" Size="Size.Small" Color="Color.Default" Variant="Variant.Outlined" Class="me-1">@tool</MudChip>
                    }
                </CellTemplate>
            </TemplateColumn>
            <TemplateColumn Title="Actions" Sortable="false" Filterable="false" CellClass="text-end">
                <CellTemplate>
                    <button class="btn btn-primary btn-sm" @onclick="() => UseTemplate(context.Item)">
                        Use this template →
                    </button>
                </CellTemplate>
            </TemplateColumn>
        </Columns>
        <ChildRowContent>
            <MudCard Elevation="0" Class="pa-3 mud-background-gray">
                @if (context.Item.RequiredSecrets.Count > 0)
                {
                    <div class="small mb-2">
                        <strong>Secrets:</strong>
                        @foreach (var s in context.Item.RequiredSecrets)
                        {
                            <MudChip T="string" Size="Size.Small" Color="Color.Warning" Variant="Variant.Filled" Class="me-1">@s</MudChip>
                        }
                    </div>
                }
                @if (context.Item.Prerequisites.Count > 0)
                {
                    <div class="small mb-2">
                        <strong>Prerequisites:</strong>
                        <ul class="mb-0 mt-1">
                            @foreach (var p in context.Item.Prerequisites)
                            {
                                <li>@p</li>
                            }
                        </ul>
                    </div>
                }
                <div class="small mb-2">
                    <strong>Prompt:</strong>
                    <pre class="bg-light p-2 rounded mt-1" style="white-space:pre-wrap;font-size:0.85em;">@context.Item.DefaultJob.Prompt</pre>
                </div>
                @if (!string.IsNullOrEmpty(context.Item.DocsUrl))
                {
                    <a href="@context.Item.DocsUrl" target="_blank" class="small">📖 Read the demo</a>
                }
            </MudCard>
        </ChildRowContent>
        <PagerContent>
            <MudDataGridPager T="JobTemplateDto" PageSizeOptions="new[] { 10, 25, 50, 100 }" />
        </PagerContent>
    </MudDataGrid>
}

@if (_lastError is not null)
{
    <div class="alert alert-danger mt-4">@_lastError</div>
}

@code {
    private List<JobTemplateDto> _templates = [];
    private bool _loading = true;
    private bool _dense = true;
    private string? _error;
    private string? _lastError;

    protected override async Task OnInitializedAsync()
    {
        try
        {
            _templates = (await JobsClient.ListTemplatesAsync()).ToList();
        }
        catch (Exception ex)
        {
            _error = $"Failed to load templates: {ex.Message}";
        }
        finally
        {
            _loading = false;
        }
    }

    private async Task UseTemplate(JobTemplateDto template)
    {
        _lastError = null;
        try
        {
            var created = await JobsClient.CreateAsync(template.DefaultJob);
            Navigation.NavigateTo($"/jobs/{created.Id}");
        }
        catch (Exception ex)
        {
            _lastError = $"Failed to create job from template '{template.Id}': {ex.Message}";
        }
    }
}
