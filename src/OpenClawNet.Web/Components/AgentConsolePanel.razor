@using System.Collections.Generic
@using System.Diagnostics
@inject IJSRuntime JS
@implements IAsyncDisposable

<div class="agent-console-panel border-top bg-dark text-light mt-3" style="max-height: 300px; overflow-y: auto;"
     data-testid="agent-activity-panel">
    <div class="d-flex justify-content-between align-items-center p-2 border-bottom bg-secondary">
        <strong>Agent Activity</strong>
        <div class="gap-2 d-flex">
            <button class="btn btn-sm btn-outline-light" @onclick="ClearLogs" title="Clear">Clear</button>
            <button class="btn btn-sm btn-outline-light" @onclick="TogglePanel" title="Collapse/Expand"
                    data-testid="agent-activity-toggle">
                @(IsExpanded ? "▼" : "▶")
            </button>
        </div>
    </div>

    @if (IsExpanded)
    {
        <div class="logs-container p-2" id="agent-activity-log" data-testid="agent-activity-log"
             style="font-family: 'Courier New', monospace; font-size: 0.9rem; white-space: pre-wrap; word-break: break-word; max-height: 240px; overflow-y: auto;">
            @if (_logEntries.Count == 0)
            {
                <div class="text-muted small">Waiting for agent activity…</div>
            }
            @foreach (var entry in _logEntries.TakeLast(100))
            {
                <div class="log-entry mb-1" style="@GetLogStyle(entry.Level)">
                    <span class="timestamp">[<small>@entry.Timestamp.ToString("HH:mm:ss.fff")</small>]</span>
                    <span class="level" style="display: inline-block; width: 60px; font-weight: bold;">@entry.Level</span>
                    <span class="message">@entry.Message</span>
                </div>
            }
        </div>
    }
</div>

@code {
    private const string LogElementId = "agent-activity-log";
    private List<LogEntry> _logEntries = new();
    private bool IsExpanded = true;
    private bool _attached;

    public void AddLog(string level, string message)
    {
        _logEntries.Add(new LogEntry
        {
            Level = level,
            Message = message,
            Timestamp = DateTime.Now
        });

        // Keep only last 100 entries
        if (_logEntries.Count > 100)
            _logEntries.RemoveAt(0);

        InvokeAsync(StateHasChanged);
    }

    public void AddToolCall(string toolName, Dictionary<string, object> parameters)
    {
        var paramStr = string.Join(", ", parameters.Select(p => $"{p.Key}={p.Value}"));
        AddLog("TOOL", $"→ {toolName}({paramStr})");
    }

    public void AddToolComplete(string toolName, object result)
    {
        AddLog("SUCCESS", $"✓ {toolName} completed");
    }

    public void AddError(string message)
    {
        AddLog("ERROR", $"✗ {message}");
    }

    private void ClearLogs()
    {
        _logEntries.Clear();
    }

    private void TogglePanel()
    {
        IsExpanded = !IsExpanded;
    }

    protected override async Task OnAfterRenderAsync(bool firstRender)
    {
        if (!IsExpanded) return;
        try
        {
            if (!_attached)
            {
                await JS.InvokeVoidAsync("activityTail.attach", LogElementId);
                _attached = true;
            }
            await JS.InvokeVoidAsync("activityTail.scrollToBottom", LogElementId);
        }
        catch
        {
            // JS interop unavailable during prerender — retry next render.
        }
    }

    public async ValueTask DisposeAsync()
    {
        try { await JS.InvokeVoidAsync("activityTail.detach", LogElementId); }
        catch { }
    }

    private string GetLogStyle(string level) => level switch
    {
        "ERROR" => "color: #ff6b6b;",      // Red
        "SUCCESS" => "color: #51cf66;",    // Green
        "TOOL" => "color: #4dabf7;",       // Blue
        "WARNING" => "color: #ffd43b;",    // Yellow
        _ => "color: #d0bfff;"             // Purple (default)
    };

    private class LogEntry
    {
        public string Level { get; set; }
        public string Message { get; set; }
        public DateTime Timestamp { get; set; }
    }
}

<style>
.agent-console-panel {
    position: relative;
    border-radius: 4px;
    box-shadow: 0 -2px 8px rgba(0, 0, 0, 0.15);
}

.logs-container {
    background-color: #1a1a1a;
    color: #d0d0d0;
    line-height: 1.6;
}

.log-entry {
    display: flex;
    gap: 12px;
    font-size: 0.85rem;
}

.log-entry .timestamp {
    color: #888;
    flex-shrink: 0;
}

.log-entry .level {
    font-weight: bold;
    flex-shrink: 0;
    text-transform: uppercase;
}

.log-entry .message {
    flex-grow: 1;
    word-break: break-word;
}
</style>
